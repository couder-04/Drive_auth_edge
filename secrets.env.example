# Copy to secrets.env (gitignored) and fill in values.
# Or set the same keys as Railway / shell environment variables.
# Load order: existing env wins, then secrets.env / DRIVEAUTH_SECRETS_FILE.
#
# Provider (default env = this file). See docs/key-provisioning.md.
# DRIVEAUTH_SECRETS_PROVIDER=env          # env | vault | hsm
# DRIVEAUTH_SECRETS_FILE=/var/driveauth/secrets.env
#
# HashiCorp Vault KV v2 (when DRIVEAUTH_SECRETS_PROVIDER=vault):
# DRIVEAUTH_VAULT_ADDR=https://vault.example:8200
# DRIVEAUTH_VAULT_TOKEN=
# DRIVEAUTH_VAULT_MOUNT=secret
# DRIVEAUTH_VAULT_PATH=driveauth/vehicles/vehicle_01
#
# hsm = stub until a real HSM backend is wired; do not enable in production.

# ── OpenRouter (STT + TTS + LLM slot-fill) ───────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_STT_MODEL=openai/whisper-1
OPENROUTER_TTS_MODEL=openai/gpt-4o-mini-tts
OPENROUTER_LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_TTS_VOICE=alloy
# Optional override (default https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Google Maps JS (browser home / location pickers) ─────────────────
GOOGLE_MAPS_API_KEY=

# ── DriveAuth standalone stores (use the SAME path for register + auth)
DRIVEAUTH_USE_MOCK=0
DRIVEAUTH_DASHBOARD_STORE=./driveauth_store_phase2a
DRIVEAUTH_REGISTER_STORE=./driveauth_store_phase2a
DRIVEAUTH_DATA_ROOT=./data
DRIVEAUTH_DEFAULT_DRIVER=driver1
