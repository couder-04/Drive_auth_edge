# ============================================================================
# DO NOT SOURCE BLINDLY — DEMO / DRIVER7 UX ONLY
# ============================================================================
# These exports LOWER the security floor so weak Stage-2 scores can ACCEPT.
# They do NOT improve biometric separation. Stock policy.yaml bars remain:
#   LADDER voice=0.72  face=0.70  finger=0.70
#   TRUST  micro=0.70  std=0.78   high=0.85  reject=0.48
#
# Current deltas vs stock (driver7 calibration / phase2b_calibration_driver7.json):
#   voice  0.72 → 0.58   (−0.14)
#   face   0.70 → 0.36   (−0.34)
#   trust  micro/std/high/reject all cut ~0.15–0.24
#
# Dashboard startup prints a loud WARNING if any of these are in the environment.
# See docs/security-assumptions.md §6. Prefer fixing scores (enrollment / heads)
# over shipping these bars.
# ============================================================================

export DRIVEAUTH_TRUST_ACCEPT_MICRO=0.554
export DRIVEAUTH_TRUST_ACCEPT_STD=0.584
export DRIVEAUTH_TRUST_ACCEPT_HIGH=0.614
export DRIVEAUTH_TRUST_REJECT=0.419
export DRIVEAUTH_LADDER_ACCEPT_VOICE=0.58
export DRIVEAUTH_LADDER_ACCEPT_FACE=0.36
export DRIVEAUTH_LADDER_ACCEPT_FINGER=0.7
